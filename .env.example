# ============================================
# MCP Connection-Key System - .env Konfiguration
# ============================================
# Kopieren Sie diese Datei zu .env und passen Sie die Werte an
# cp .env.example .env
# nano .env

# ============================================
# OPENAI API (ERFORDERLICH)
# ============================================
OPENAI_API_KEY=sk-your-openai-api-key-here
OPENAI_MODEL=gpt-4o
OPENAI_TEMPERATURE=0.7
OPENAI_MAX_TOKENS=2000

# ============================================
# n8n KONFIGURATION
# ============================================
N8N_BASE_URL=http://localhost:5678
N8N_API_KEY=
# HINWEIS: n8n >= v1.0 nutzt KEIN Basic-Auth mehr (laufende Instanz: v2.3.5). N8N_PASSWORD
# wird von n8n ignoriert; Zugang laeuft ueber den Owner-Account (User-Management in der App).
# Variable bleibt nur wegen anderer Consumer (z. B. Skripte); fuer die n8n-Auth irrelevant.
N8N_PASSWORD=secure-password-change-me
N8N_HOST=localhost
# Version pinnen: auf die AKTUELL laufende n8n-Version setzen (docker exec n8n n8n --version).
# Leer/latest = kein reproduzierbarer Pin. KEIN Downgrade gegen ein migriertes n8n_data-Volume.
N8N_VERSION=2.3.5

# ============================================
# MCP SERVER
# ============================================
MCP_SERVER_URL=http://localhost:7777
MCP_SERVER_TIMEOUT=30000

# ============================================
# CHATGPT-AGENT
# ============================================
CHATGPT_AGENT_URL=http://localhost:4000
CHATGPT_AGENT_PORT=4000
CHATGPT_AGENT_TIMEOUT=30000

# ============================================
# CONNECTION-KEY SERVER
# ============================================
PORT=3000
CONNECTION_KEY_URL=http://localhost:3000

# ============================================
# AUTHENTICATION
# ============================================
AUTH_ENABLED=true
API_KEY=your-secure-api-key-change-me
CONNECTION_KEY_API_KEY=your-secure-api-key-change-me
JWT_SECRET=your-super-secret-jwt-key-change-me-in-production
JWT_EXPIRES_IN=24h

# ============================================
# CORS KONFIGURATION
# ============================================
CORS_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:8080

# ============================================
# RATE LIMITING
# ============================================
RATE_LIMIT_ENABLED=true
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=100

# ============================================
# LOGGING
# ============================================
LOG_LEVEL=info
LOG_FORMAT=json

# ============================================
# RUNWAY / SEEDANCE 2.0 VIDEO-GENERIERUNG
# ============================================
# API-Key aus dem Runway Developer Portal (https://dev.runwayml.com)
# Wird vom mcp-gateway (/agent/video/generate) und vom Skill genutzt.
RUNWAYML_API_SECRET=your-runway-api-secret-here
# Optionaler Modell-Override (Default: seedance2)
RUNWAY_VIDEO_MODEL=seedance2

# ============================================
# DOCKER KONFIGURATION
# ============================================
NODE_ENV=production
