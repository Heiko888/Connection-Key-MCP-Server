
services:
  # n8n - Workflow Engine
  n8n:
    image: n8nio/n8n:latest
    container_name: n8n
    ports:
      - "5678:5678"
    environment:
      - N8N_BASIC_AUTH_ACTIVE=true
      - N8N_BASIC_AUTH_USER=admin
      - N8N_BASIC_AUTH_PASSWORD=${N8N_PASSWORD:-change-me}
      - N8N_HOST=${N8N_HOST:-n8n.werdemeisterdeinergedankenagent.de}
      - N8N_PORT=5678
      - N8N_PROTOCOL=${N8N_PROTOCOL:-https}
      - N8N_WEBHOOK_URL=${N8N_WEBHOOK_URL:-https://n8n.werdemeisterdeinergedankenagent.de}
      - N8N_DISABLE_UI_FEATURES=enterprise
      - N8N_ENFORCE_SETTINGS_FILE=false
      - N8N_LICENSE_AUTO_ACCEPT=false
    volumes:
      - n8n_data:/home/node/.n8n
    restart: unless-stopped
    networks:
      - app-network

  # MCP Gateway - Agent Orchestration (Port 7000)
  mcp-gateway:
    build:
      context: .
      dockerfile: Dockerfile.mcp-gateway
    container_name: mcp-gateway
    ports:
      - "7000:7000"
    environment:
      - NODE_ENV=production
      - MCP_PORT=7000
      - MCP_API_KEY=${CK_AGENT_SECRET}
      - OPENAI_API_KEY=${OPENAI_API_KEY}
      - SUPABASE_URL=${SUPABASE_URL}
      - SUPABASE_SERVICE_KEY=${SUPABASE_SERVICE_KEY}
      - ANTHROPIC_API_KEY=${ANTHROPIC_API_KEY}
    restart: unless-stopped
    networks:
      - app-network

  # Sync Reading Service
  sync-reading-service:
    build:
      context: /opt/ck-agent/sync-reading-service
      dockerfile: Dockerfile
    container_name: sync-reading-service
    ports:
      - "7001:7001"
    environment:
      - NODE_ENV=production
      - PORT=7001
      - ANTHROPIC_API_KEY=${ANTHROPIC_API_KEY}
    restart: unless-stopped
    networks:
      - app-network
    healthcheck:
      test: ["CMD", "wget", "--no-verbose", "--tries=1", "--spider", "http://localhost:7001/health"]
      interval: 30s
      timeout: 3s
      retries: 3
      start_period: 10s

  # Connection-Key Server
  connection-key:
    build:
      context: .
      dockerfile: Dockerfile.connection-key
    container_name: connection-key
    env_file:
      - .env
    ports:
      - "3000:3000"
    environment:
      - NODE_ENV=production
      - PORT=3000
      - SUPABASE_URL=${SUPABASE_URL}
      - SUPABASE_SERVICE_KEY=${SUPABASE_SERVICE_KEY}
      - MCP_SERVER_URL=http://mcp-gateway:7000
      - READING_AGENT_URL=${READING_AGENT_URL:-http://localhost:4000}
      - N8N_BASE_URL=http://n8n:5678
      - AUTH_ENABLED=${AUTH_ENABLED:-true}
      - API_KEY=${API_KEY:-}
      - CORS_ORIGINS=${CORS_ORIGINS:-*}
    depends_on:
      - n8n
      - mcp-gateway
    restart: unless-stopped
    networks:
      - app-network

  # Frontend
  frontend:
    image: node:20-alpine
    container_name: connection-key-frontend
    working_dir: /app
    volumes:
      - ./frontend:/app
    command: sh -c "npm install && npx next dev -p 3005"
    ports:
      - "3005"
    restart: unless-stopped
    networks:
      - app-network

  # Nginx Reverse Proxy
  nginx:
    image: nginx:alpine
    container_name: connection-key-nginx
    ports:
      - "80:80"
      - "443:443"
    volumes:
      - ./nginx/conf.d:/etc/nginx/conf.d:ro
      - /etc/letsencrypt:/etc/letsencrypt:ro
    depends_on:
      - connection-key
      - frontend
    restart: unless-stopped
    networks:
      - app-network

  # Redis (für reading-worker benötigt)
  redis:
    image: redis:7-alpine
    container_name: redis
    restart: unless-stopped
    networks:
      - app-network
    healthcheck:
      test: ["CMD", "redis-cli", "ping"]
      interval: 10s
      timeout: 3s
      retries: 5

  # Reading Worker (Produktiv)
  reading-worker:
    build:
      context: ./reading-worker
    container_name: reading-worker
    dns:
      - 8.8.8.8
      - 8.8.4.4
    ports:
      - "4000:4000"
    volumes:
      - ./production/templates:/app/templates:ro
      - ./production/knowledge:/app/knowledge:ro
    env_file:
      - .env
    environment:
      NODE_ENV: production
      USE_CLAUDE: "true"
      ANTHROPIC_API_KEY: ${ANTHROPIC_API_KEY}
      CLAUDE_TIMEOUT_MS: ${CLAUDE_TIMEOUT_MS:-120000}
    depends_on:
      redis:
        condition: service_healthy
    restart: unless-stopped
    networks:
      - app-network

volumes:
  n8n_data:

networks:
  app-network:
    driver: bridge
