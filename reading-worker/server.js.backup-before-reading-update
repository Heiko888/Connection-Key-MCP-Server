        return {
          agentId,
          reading: agentReading,
          insights: extractInsights(agentReading, agentId)
        };
      });

      // Warte auf alle Agents
      const agentResults = await Promise.all(agentPromises);

      // 4. Progress Update
      await supabase
        .from("reading_jobs")
        .update({ progress: 60 })
        .eq("reading_id", readingId);

      // 5. Synthesis erstellen (wenn enabled)
      let synthesisResult = null;
      let combinedInsights = [];
      let crossReferences = [];

      if (synthesis) {
        console.log("🔄 [Multi-Agent] Erstelle Synthesis...");

        synthesisResult = await generateMultiAgentSynthesis(
          agentResults,
          birthData,
          knowledge
        );

        // Extract insights aus allen Readings
        combinedInsights = agentResults.flatMap(r => r.insights);

        // Cross-References finden (wo Agents ähnliche Punkte ansprechen)
        crossReferences = findCrossReferences(agentResults);

